: "${DEFAULT_DOTFILES_REPO:=}"
: "${APPLY_CHEZMOI:=true}"
: "${CHSH_TO_ZSH:=true}"
: "${ENABLE_DOCKER:=true}"
: "${INSTALL_MISE:=true}"
: "${MISE_GLOBAL_TOOLS:=ruby@latest python@latest node@latest rust@latest terraform@latest awscli@latest}"
: "${INSTALL_SYSTEM_SERVICES:=true}"
: "${ENABLE_SSH_SERVICE:=true}"
: "${INSTALL_SYNCTHING:=true}"
: "${ENABLE_SYNCTHING_SERVICE:=true}"
: "${INSTALL_TAILSCALE:=true}"
: "${ENABLE_TAILSCALE_SERVICE:=true}"
: "${INSTALL_FLATPAK_APPS:=true}"
: "${INSTALL_OBSIDIAN:=true}"
: "${INSTALL_BITWARDEN_FLATPAK:=true}"
: "${INSTALL_CLI_TOOLS:=true}"
: "${INSTALL_OPENCODE:=true}"
: "${INSTALL_TGCLI:=true}"
: "${INSTALL_NGROK:=true}"
: "${INSTALL_STRIPE_CLI:=true}"
: "${INSTALL_BW_WRAPPER:=true}"

export DEFAULT_DOTFILES_REPO
export APPLY_CHEZMOI
export CHSH_TO_ZSH
export ENABLE_DOCKER
export INSTALL_MISE
export MISE_GLOBAL_TOOLS
export INSTALL_SYSTEM_SERVICES
export ENABLE_SSH_SERVICE
export INSTALL_SYNCTHING
export ENABLE_SYNCTHING_SERVICE
export INSTALL_TAILSCALE
export ENABLE_TAILSCALE_SERVICE
export INSTALL_FLATPAK_APPS
export INSTALL_OBSIDIAN
export INSTALL_BITWARDEN_FLATPAK
export INSTALL_CLI_TOOLS
